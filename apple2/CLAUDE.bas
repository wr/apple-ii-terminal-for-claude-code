1 REM CLAUDE ][ CLIENT
10 GOSUB 900
20 ET=4:HP=1403
23 POKE 50,255
25 PRINT CHR$(4);"PR#3"
26 PRINT CHR$(14);:NORMAL
28 POKE 32,0:POKE 33,80
30 POKE 49186,160
32 POKE 49204,INT(PEEK(49204)/16)*16
40 BR$="":FOR I=1 TO 78:BR$=BR$+"-":NEXT
50 POKE 34,0:POKE 35,24:HOME
60 GOSUB 950
70 GOSUB 800
100 REM MAIN LOOP
110 GOSUB 300
120 IF L$="" THEN 110
130 VTAB 21:POKE HP,0:PRINT "> ";L$
140 FOR I=1 TO LEN(L$):POKE DB,ASC(MID$(L$,I,1)):NEXT:POKE DB,13
150 GOSUB 400
160 GOSUB 500
165 GOSUB 800
170 PRINT:GOTO 110
300 REM INPUT IN THE BOX
310 POKE 35,24:VTAB 23:POKE HP,2:L$=""
320 GET A$:C=ASC(A$)
330 IF C=13 THEN GOSUB 830:POKE 35,21:VTAB 21:RETURN
340 IF C=8 OR C=127 THEN GOSUB 380:GOTO 320
350 IF C>=32 AND LEN(L$)<74 THEN L$=L$+A$:PRINT A$;
360 GOTO 320
380 IF LEN(L$)=0 THEN RETURN
385 IF LEN(L$)=1 THEN L$="":PRINT CHR$(8);" ";CHR$(8);:RETURN
390 L$=LEFT$(L$,LEN(L$)-1):PRINT CHR$(8);" ";CHR$(8);:RETURN
400 REM STAR SPINNER UNTIL REPLY
405 VTAB 21:POKE HP,0
410 FR=0
420 GOSUB 620:IF RR=1 THEN IF FR>50 THEN 470
430 ST$="*":IF FR-INT(FR/2)*2=1 THEN ST$="+"
440 WX=INT(FR/8):WX=WX-INT(WX/8)*8:DT=FR-INT(FR/4)*4
450 F$=ST$+" "+WD$(WX)+DA$(DT)+"    "
460 PRINT F$;:FOR J=1 TO LEN(F$):PRINT CHR$(8);:NEXT:FOR D=1 TO 90:NEXT:FR=FR+1:GOTO 420
470 VTAB 21:POKE HP,0:PRINT CHR$(29);:VTAB 21:POKE HP,0:RETURN
500 REM REPLY UNTIL EOT
510 GOSUB 620:IF RR=0 THEN 510
520 C=PEEK(DB):C=C-INT(C/128)*128
530 IF C=ET THEN RETURN
540 IF C<>10 THEN PRINT CHR$(C);
550 GOTO 510
600 REM DRAIN STALE RX
610 GOSUB 620:IF RR=1 THEN C=PEEK(DB):GOTO 610
615 RETURN
620 S=PEEK(SB):R=INT(S/RM):RR=R-INT(R/2)*2:RETURN
800 REM DRAW FULL BOX
805 POKE 35,24
810 VTAB 22:POKE HP,0:PRINT BR$;
815 VTAB 24:POKE HP,0:PRINT BR$;
820 GOSUB 830
825 POKE 35,21:VTAB 21:RETURN
830 VTAB 23:POKE HP,0:PRINT "> ";:PRINT CHR$(29);:POKE HP,2:RETURN
900 REM MACHINE DETECT AND SERIAL SETUP
910 POKE 768,56:POKE 769,32:POKE 770,31:POKE 771,254:POKE 772,169:POKE 773,0:POKE 774,176:POKE 775,2:POKE 776,169:POKE 777,1:POKE 778,133:POKE 779,6:POKE 780,96
920 CALL 768:GS=PEEK(6)
930 IF GS=1 THEN SB=49208:DB=49210:RM=1:TM=4:GOTO 945
935 SB=49321:DB=49320:RM=8:TM=16
940 POKE 49323,30:POKE 49322,9
945 DIM WD$(7),DA$(3)
946 WD$(0)="COGITATING":WD$(1)="CLAUDING":WD$(2)="COOKING":WD$(3)="PERCOLATING":WD$(4)="MUSING":WD$(5)="NOODLING":WD$(6)="CONJURING":WD$(7)="PONDERING"
947 DA$(0)="   ":DA$(1)=".  ":DA$(2)=".. ":DA$(3)="..."
948 RETURN
950 REM BANNER (CLAUDE MASCOT)
955 VTAB 2:POKE HP,4:INVERSE:PRINT "      ";:NORMAL
960 VTAB 3:POKE HP,4:INVERSE:PRINT "  ";:NORMAL:PRINT "  ";:INVERSE:PRINT "  ";:NORMAL:POKE HP,14:PRINT "Claude Code v2.1.204"
965 VTAB 4:POKE HP,3:INVERSE:PRINT "        ";:NORMAL:POKE HP,14:PRINT "Opus 4.8 (1M) - high effort"
970 VTAB 5:POKE HP,4:INVERSE:PRINT " ";:NORMAL:PRINT " ";:INVERSE:PRINT " ";:NORMAL:PRINT " ";:INVERSE:PRINT " ";:NORMAL:PRINT " ";:INVERSE:PRINT " ";:NORMAL:POKE HP,14:PRINT "Apple II <-> Claude Code"
975 RETURN
